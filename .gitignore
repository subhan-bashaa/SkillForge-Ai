.installed.cfg
*.egg
MANIFEST

# Flask / virtual environments
venv/
.venv/
ENV/
env/
pythonenv*/
pip-selfcheck.json

# SQLite & Databases
*.db
*.sqlite
*.sqlite3
instance/

# Node.js (React / Vite)
node_modules/
